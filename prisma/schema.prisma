generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id            String   @id @default(cuid())
  ticker        String
  version       Int      @default(1)
  isCurrent     Boolean  @default(true)
  companyName   String
  totalRating   Int      
  verdict       String   
  
  moat          Int
  management    Int
  valuation     Int
  growth        Int
  profitability Int
  financials    Int
  risk          Int
  trend         Int

  analysisText  String
  createdAt     DateTime @default(now())

  @@unique([ticker, version])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}

model MacroMarketData {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Float
  source    String
  trend     String?  // "up", "down", "flat"
  updatedAt DateTime @updatedAt
}

model MarketEvent {
  id                String   @id @default(cuid())
  title             String
  impact            String   // "positive", "negative", "neutral"
  description       String
  whyItMatters      String
  swedishCompanies  String
  usCompanies       String
  winners           String
  createdAt         DateTime @default(now())
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now())
  watchlists    Watchlist[]
  notifications Notification[]
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  ticker    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, ticker])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  ticker    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model Vote {
  id        String   @id @default(cuid())
  stock     String
  source    String?  @default("email")
  createdAt DateTime @default(now())

  @@map("votes")
}



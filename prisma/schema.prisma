generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id            String   @id @default(cuid())
  ticker        String
  version       Int      @default(1)
  isCurrent     Boolean  @default(true)
  companyName   String
  totalRating   Int      
  verdict       String   
  
  moat          Int
  management    Int
  valuation     Int
  growth        Int
  profitability Int
  financials    Int
  risk          Int
  trend         Int

  analysisText  String
  createdAt     DateTime @default(now())

  @@unique([ticker, version])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}

model MacroMarketData {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Float
  source    String
  trend     String?  // "up", "down", "flat"
  updatedAt DateTime @updatedAt
}

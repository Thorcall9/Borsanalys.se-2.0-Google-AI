{
  "crons": [
    {
      "path": "/api/admin/update-macro",
      "schedule": "0 5 * * *" 
    }
  ],
  "rewrites": [
    { "source": "/analyser/rss", "destination": "/api/rss" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/newsletter/signup.ts": {
      "maxDuration": 10
    }
  }
}
